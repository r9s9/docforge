# Local dev: the Next server proxies /api -> BACKEND_URL (see next.config.mjs).
BACKEND_URL=http://localhost:8000

# Split deployment (e.g. Vercel frontend + separately hosted backend):
# the browser calls the backend directly at this origin instead of /api.
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com

# Supabase Auth (accounts). Project URL + anon (publishable) key, from
# Supabase dashboard -> Project Settings -> API. These are safe to expose to the
# browser. The backend separately needs DOCFORGE_SUPABASE_JWT_SECRET (the JWT
# secret, kept server-side) to verify the tokens these issue.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
