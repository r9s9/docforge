# ---------------------------------------------------------------------------
# DocForge environment configuration
# Copy this file to ".env" and adjust as needed. Do NOT commit your real .env.
# ---------------------------------------------------------------------------

# --- Core ---
DOCFORGE_ENV=development
DOCFORGE_DEBUG=true
DOCFORGE_DATA_DIR=./data                 # where uploads, templates, generated docs live
DOCFORGE_DATABASE_URL=sqlite:///./data/docforge.db
# Production: a managed Postgres (e.g. Supabase Session-pooler URI):
# DOCFORGE_DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Accounts / Auth (Supabase) --------------------------------------------
# When auth_required, API routes require a Supabase JWT and scope data per-user.
# Leave auth off for fully local single-user use (no Supabase needed).
DOCFORGE_AUTH_REQUIRED=false
DOCFORGE_SUPABASE_URL=                    # https://<ref>.supabase.co
DOCFORGE_SUPABASE_JWT_SECRET=            # Project Settings -> API -> JWT secret (server-side)
# Allowed CORS origins (the deployed frontend). "*" for local dev.
DOCFORGE_CORS_ALLOW_ORIGINS=*

# --- File storage ----------------------------------------------------------
# "local" = filesystem under DOCFORGE_DATA_DIR (dev / hosts with a disk).
# "supabase" = Supabase Storage bucket (required on disk-less hosts so files
# survive restarts). The service-role key is a SERVER-SIDE secret.
DOCFORGE_STORAGE_BACKEND=local
DOCFORGE_SUPABASE_SERVICE_ROLE_KEY=
DOCFORGE_SUPABASE_STORAGE_BUCKET=docforge

# --- Uploads / safety ---
DOCFORGE_MAX_UPLOAD_MB=25                 # per-file upload limit
DOCFORGE_MAX_FILES_PER_ANALYSIS=5
DOCFORGE_ZIP_MAX_TOTAL_MB=200            # zip-bomb guard: max uncompressed size
DOCFORGE_ZIP_MAX_ENTRIES=2000           # zip-bomb guard: max entries in a docx

# --- AI provider -----------------------------------------------------------
# Provider is OpenAI-compatible. Point it at OpenAI, a local server
# (Ollama / LM Studio / llama.cpp with an OpenAI shim), or any compatible API.
#
# If DOCFORGE_AI_ENABLED=false (or no API key is set) DocForge falls back to a
# fully deterministic, heuristic classifier/router so the app runs offline with
# NO external calls. This keeps the system local-first and privacy-aware.
DOCFORGE_AI_ENABLED=false
DOCFORGE_AI_BASE_URL=https://api.openai.com/v1
DOCFORGE_AI_API_KEY=
DOCFORGE_AI_MODEL=gpt-4o-mini
DOCFORGE_AI_TIMEOUT_SECONDS=60
DOCFORGE_AI_MAX_RETRIES=2

# Example local config (Ollama):
# DOCFORGE_AI_ENABLED=true
# DOCFORGE_AI_BASE_URL=http://localhost:11434/v1
# DOCFORGE_AI_API_KEY=ollama
# DOCFORGE_AI_MODEL=llama3.1

# --- Free-tier AI (shared key, paid by the platform; users never see it) -----
# Give every signed-in user a small allowance of free AI actions on a shared
# key you provide (e.g. a cheap Claude Haiku key). After the allowance is spent,
# the user must add their OWN key (Settings -> AI) for unlimited AI; otherwise
# DocForge falls back to the offline heuristic engine. When enabled, the free
# tier supersedes the global DOCFORGE_AI_* key for users without their own key.
# The key is read from the environment ONLY and is never returned to the client.
DOCFORGE_FREE_AI_ENABLED=false
DOCFORGE_FREE_AI_PROVIDER=anthropic
DOCFORGE_FREE_AI_BASE_URL=https://api.anthropic.com
DOCFORGE_FREE_AI_MODEL=claude-haiku-4-5-20251001
DOCFORGE_FREE_AI_API_KEY=                # sk-ant-... (secret — set in your host's dashboard)
DOCFORGE_FREE_AI_LIMIT=10               # free AI actions per user

# --- Logging ---
DOCFORGE_LOG_LEVEL=INFO
DOCFORGE_LOG_REDACT=true                  # redact extracted document text from logs

# --- Frontend ---
# Base URL the web app uses to reach the API (used at build/runtime by Vite).
VITE_API_BASE_URL=http://localhost:8000
